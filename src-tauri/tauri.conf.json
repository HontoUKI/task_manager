{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Basic Overlay",
  "version": "0.1.0",
  "identifier": "dev.local.basic-overlay",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Basic Overlay",
        "label": "main",
        "width": 460,
        "height": 620,
        "minWidth": 360,
        "minHeight": 420,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
